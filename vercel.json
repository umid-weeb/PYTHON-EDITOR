{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "redirects": [
    {
      "source": "/arena",
      "destination": "/zone",
      "permanent": true
    },
    {
      "source": "/arena/(.*)",
      "destination": "/zone/$1",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "http://16.16.26.138:8000/api/$1"
    },
    {
      "source": "/uploads/(.*)",
      "destination": "http://16.16.26.138:8000/uploads/$1"
    },
    {
      "source": "/zone/(.*)",
      "destination": "/zone/index.html"
    },
    {
      "source": "/zone",
      "destination": "/zone/index.html"
    }
  ]
}
